# Copy to .env and fill in. Real keys are never committed.

# Supabase project URL (FOGO production project)
SUPABASE_URL=https://avlhnogtosjxdyibjipz.supabase.co

# Anon / publishable key (sb_publishable_...). SELECT-only via RLS; used at
# build time only — it is never shipped in client JS.
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Which brand this build produces. Must match public.brand_sites.slug.
BRAND_SLUG=bean-envy

# Service role key — ONLY needed locally for scripts/mirror-images.mjs
# (uploads to the brand-site-images bucket + writes bronze.brand_site_images).
# Never used by the site build. Never commit.
SUPABASE_SERVICE_ROLE_KEY=
