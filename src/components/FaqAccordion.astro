---
// Native <details> accordion — keyboard and screen-reader behavior for free,
// no JS. Props: items [{ question, answer }] (answer is plain text; may
// contain \n\n for paragraphs).
const { items = [] } = Astro.props;
---

<div class="border-t border-[var(--line)]">
  {
    items.map(({ question, answer }) => (
      <details class="faq-item group border-b border-[var(--line)]">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 font-semibold [&::-webkit-details-marker]:hidden">
          {question}
          <span
            class="relative h-4 w-4 shrink-0 text-[var(--accent-ink,var(--ink))] transition-transform duration-200 group-open:rotate-45 motion-reduce:transition-none"
            aria-hidden="true"
          >
            <span class="absolute left-1/2 top-0 h-full w-0.5 -translate-x-1/2 rounded bg-current" />
            <span class="absolute left-0 top-1/2 h-0.5 w-full -translate-y-1/2 rounded bg-current" />
          </span>
        </summary>
        <div class="pb-5 pr-8 leading-relaxed text-[var(--mist,var(--ink))]">
          {answer.split('\n\n').map((para) => (
            <p class="mb-3 last:mb-0">{para}</p>
          ))}
        </div>
      </details>
    ))
  }
</div>
