---
import { getBrand } from '../lib/supabase.js';
import { localBucketImage } from '../lib/images.js';

// Hero layout variant comes from brand_sites.hero_style:
//   'split'      — text beside the hero image (default when an image exists)
//   'full-bleed' — edge-to-edge hero image with a dark overlay and white text
//   'minimal'    — centered text on the brand color, no image
const brand = await getBrand();
const wantsImage = brand.hero_style !== 'minimal' && Boolean(brand.hero_image_path);
const style = brand.hero_style ?? (wantsImage ? 'split' : 'minimal');
const heroImage = wantsImage
  ? await localBucketImage(brand.hero_image_path, style === 'full-bleed' ? 1600 : 1000)
  : null;
---

{
  style === 'full-bleed' && heroImage ? (
    <section class="relative overflow-hidden">
      <img
        src={heroImage}
        alt=""
        width="1600"
        height="1000"
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-black/10" aria-hidden="true" />
      <div class="relative mx-auto max-w-6xl px-4 py-28 sm:py-40">
        <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-white max-w-2xl">{brand.brand}</h1>
        {brand.tagline && <p class="mt-4 text-xl sm:text-2xl font-semibold text-white/90 max-w-xl">{brand.tagline}</p>}
        <div class="mt-8">
          <a
            href="/products/"
            class="inline-flex items-center rounded-full bg-[var(--brand)] px-8 py-4 text-lg font-bold no-underline shadow hover:opacity-90 transition-opacity"
            style="color: var(--brand-2);"
          >
            Shop the collection
          </a>
        </div>
      </div>
    </section>
  ) : (
    <section class="bg-[var(--brand)]">
      <div
        class:list={[
          'mx-auto max-w-6xl px-4 py-16 sm:py-20',
          heroImage ? 'grid items-center gap-10 lg:grid-cols-2' : 'text-center py-20 sm:py-28',
        ]}
      >
        <div class:list={[heroImage ? 'text-center lg:text-left' : '']}>
          <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight" style="color: var(--brand-2);">
            {brand.brand}
          </h1>
          {
            brand.tagline && (
              <p class="mt-4 text-xl sm:text-2xl font-semibold" style="color: var(--brand-2);">
                {brand.tagline}
              </p>
            )
          }
          <div class="mt-8">
            <a
              href="/products/"
              class="inline-flex items-center rounded-full bg-[var(--brand-2)] px-8 py-4 text-lg font-bold text-white no-underline shadow hover:opacity-90 transition-opacity"
            >
              Shop the collection
            </a>
          </div>
        </div>
        {
          heroImage && (
            <img
              src={heroImage}
              alt={`${brand.brand} — ${brand.tagline ?? 'lifestyle'}`}
              width="1000"
              height="1000"
              fetchpriority="high"
              decoding="async"
              class="w-full max-w-lg mx-auto rounded-3xl shadow-lg"
            />
          )
        }
      </div>
    </section>
  )
}
