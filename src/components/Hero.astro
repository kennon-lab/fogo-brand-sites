---
import { getBrand } from '../lib/supabase.js';
import { localBucketImage } from '../lib/images.js';

const brand = await getBrand();
const heroImage = brand.hero_image_path ? await localBucketImage(brand.hero_image_path, 1000) : null;
---

<section class="bg-[var(--brand)]">
  <div
    class:list={[
      'mx-auto max-w-6xl px-4 py-16 sm:py-20',
      heroImage ? 'grid items-center gap-10 lg:grid-cols-2' : 'text-center py-20 sm:py-28',
    ]}
  >
    <div class:list={[heroImage ? 'text-center lg:text-left' : '']}>
      <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight" style="color: var(--brand-2);">
        {brand.brand}
      </h1>
      {
        brand.tagline && (
          <p class="mt-4 text-xl sm:text-2xl font-semibold" style="color: var(--brand-2);">
            {brand.tagline}
          </p>
        )
      }
      <div class="mt-8">
        <a
          href="/products/"
          class="inline-flex items-center rounded-full bg-[var(--brand-2)] px-8 py-4 text-lg font-bold text-white no-underline shadow hover:opacity-90 transition-opacity"
        >
          Shop the collection
        </a>
      </div>
    </div>
    {
      heroImage && (
        <img
          src={heroImage}
          alt={`${brand.brand} — ${brand.tagline ?? 'lifestyle'}`}
          width="1000"
          height="1000"
          fetchpriority="high"
          decoding="async"
          class="w-full max-w-lg mx-auto rounded-3xl shadow-lg"
        />
      )
    }
  </div>
</section>
