---
// Tape King header (mockup parity): sticky, blurred paper, type-set wordmark,
// mono reorder CTA, yardage tick strip underneath.
//
import Ticks from './Ticks.astro';
import Wordmark from './Wordmark.astro';
import { getTapeCatalog, lineHref } from '../../../lib/tapeking.js';

const { lines } = await getTapeCatalog();
const bySlug = new Map(lines.map((l) => [l.slug, l]));
const std = bySlug.get('standard-clear');

const nav = [
  { label: 'Packing Tape', href: lineHref(std) },
  { label: 'Gaffers Tape', href: lineHref(bySlug.get('gaffers')) },
  { label: 'Dispensers', href: lineHref(bySlug.get('dispenser-guns')) },
  { label: 'Which tape do I need?', href: '/#cmp' },
];

// Reorder CTA: Attribution URL when one exists for the flagship SKU, plain
// Amazon fallback until then (scope §8).
const reorderSku = std.skus.find((s) => s.asin === std.representative_asin);
---

<header class="sticky top-0 z-50 border-b border-[var(--line)] bg-[rgba(250,250,248,0.94)] backdrop-blur-lg">
  <div class="mx-auto flex h-16 max-w-6xl items-center gap-3 px-3 sm:gap-7 sm:px-6">
    <a href="/" class="shrink-0 no-underline" aria-label="Tape King home">
      <Wordmark class="text-xl" />
    </a>
    <nav class="hidden gap-1 md:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="px-2.5 py-1.5 text-[14.5px] font-medium text-[var(--steel)] no-underline hover:text-[var(--ink)]"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <a
      href={reorderSku.attribution_url ?? reorderSku.amazon_url}
      target="_blank"
      rel="sponsored noopener"
      data-amazon-cta
      data-asin={reorderSku.asin}
      data-cta-position="header"
      class="ml-auto whitespace-nowrap rounded-[6px] bg-[var(--ink)] px-3 py-2.5 font-mono text-xs font-semibold text-white no-underline hover:bg-black sm:px-4 sm:text-[13px]"
    >
      REORDER ON AMAZON ↗
    </a>
  </div>
  <Ticks />
</header>
