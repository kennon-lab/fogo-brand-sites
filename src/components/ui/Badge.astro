---
// Small label pill: letterspaced caps, token colors only.
// Variants: oat (default), night, accent, outline. Slot = label text
// (optionally preceded by an inline icon, e.g. <SleepPosition />).
const { variant = 'oat' } = Astro.props;

const variantClasses =
  variant === 'night'
    ? 'bg-[var(--night,var(--ink))] text-[var(--night-ink,var(--bg))]'
    : variant === 'accent'
      ? 'bg-[color-mix(in_srgb,var(--accent)_16%,transparent)] text-[var(--accent-ink,var(--ink))]'
      : variant === 'outline'
        ? 'border border-[var(--line)] text-[var(--mist,var(--ink))]'
        : 'bg-[var(--surface-2)] text-[var(--ink)]';
---

<span
  class:list={[
    'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[var(--track-caps,0.08em)]',
    variantClasses,
  ]}
>
  <slot />
</span>
