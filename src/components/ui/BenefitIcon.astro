  stomach: '<path d="M3 22h22" /><rect x="4" y="17.5" width="8" height="2.8" rx="1.4" /><circle cx="8" cy="15" r="2.3" /><path d="M10.5 18l14.5 1.2" />',
};
---

<svg
  viewBox="0 0 28 28"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={glyphs[name] ?? '<circle cx="14" cy="14" r="9" /><circle cx="14" cy="14" r="1.5" />'}
/>
