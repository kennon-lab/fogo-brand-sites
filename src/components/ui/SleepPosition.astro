---
// Signature iconography: sleep-position glyphs (side / back / stomach /
// combination). Each is a sleeper on a pillow over a mattress line — the
// head height and spine angle differ per position, which is the actual
// information a pillow buyer needs. Draws in currentColor at any size.
// Props: position, size (px), label (visible text) — without a label the
// glyph is decorative (aria-hidden) unless `title` is passed.
const { position = 'side', size = 28, label = null, title = null } = Astro.props;

const names = {
  side: 'Side sleeper',
  back: 'Back sleeper',
  stomach: 'Stomach sleeper',
  combination: 'Combination sleeper',
};

// 32×32 grid, 2px round strokes. Mattress y=26; pillow sits at x 4–13.
const glyphs = {
  // High loft: head stacked well above the shoulder line.
  side: `
    <rect x="4" y="19" width="9" height="5" rx="2.5" />
    <circle cx="8.5" cy="14.5" r="3" />
    <path d="M11 19.5 L17 22 L22 21 L28 23" />
    <path d="M22 21 L23.5 24.5" />
  `,
  // Medium: head rests lower, spine runs nearly level.
  back: `
    <rect x="4" y="20" width="9" height="4" rx="2" />
    <circle cx="8.5" cy="16.5" r="3" />
    <path d="M11.5 20.5 L19 22 L28 22.5" />
    <path d="M19 22 L20 25" />
  `,
  // Low loft: head nearly flat, body one long line.
  stomach: `
    <rect x="4" y="21.5" width="9" height="3" rx="1.5" />
    <circle cx="8.5" cy="18.5" r="2.6" />
    <path d="M11.5 21.5 L28 23" />
  `,
  // Side glyph plus a turn arrow above the sleeper.
  combination: `
    <rect x="4" y="19" width="9" height="5" rx="2.5" />
    <circle cx="8.5" cy="14.5" r="3" />
    <path d="M11 19.5 L17 22 L22 21 L28 23" />
    <path d="M17 8 a 5 5 0 0 1 8 0" />
    <path d="M25 5.5 L25 8 L22.5 8" />
  `,
};

const glyph = glyphs[position] ?? glyphs.side;
const name = title ?? names[position] ?? names.side;
---

<span class="inline-flex items-center gap-2">
  <svg
    viewBox="0 0 32 32"
    width={size}
    height={size}
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden={label ? 'true' : title ? undefined : 'true'}
    role={!label && title ? 'img' : undefined}
    aria-label={!label && title ? name : undefined}
  >
    <path d="M3 26 H29" />
    <Fragment set:html={glyph} />
  </svg>
  {label && <span>{label}</span>}
</span>
