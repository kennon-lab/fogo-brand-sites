---
import '../styles/tokens.css';
import '../styles/global.css';
// Registered brand fonts — self-hosted at build time, so no external font
// requests at runtime. Unused @font-face rules cost only CSS bytes (browsers
// download only fonts the page actually renders). Adding a font for a new
// brand = `npm i @fontsource/<font>` + one import here.
import '@fontsource/archivo-black';
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/800.css';
import '@fontsource/michroma';
import '@fontsource/montserrat/400.css';
import '@fontsource/montserrat/600.css';
import '@fontsource/montserrat/800.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getBrand } from '../lib/supabase.js';

const brand = await getBrand();

const {
  title,
  description = brand.tagline ?? `${brand.brand} — shop our products on Amazon.`,
  ogImage = null,
  jsonLd = null,
  // GA4 outbound_amazon_click dimension; every page sets its own
  // (home | pdp | collection | catalog | about | contact | privacy).
  pageType = 'page',
} = Astro.props;

const pageTitle = title ? `${title} | ${brand.brand}` : `${brand.brand} — ${brand.tagline ?? 'Official Site'}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageAbs = ogImage ? new URL(ogImage, Astro.site).href : null;

const primary = brand.primary_color ?? '#171310';
const secondary = brand.secondary_color ?? '#5b5147';
const systemStack = `system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif`;
const fontHeading = brand.font_heading ? `'${brand.font_heading}', ${systemStack}` : systemStack;
const fontBody = brand.font_body ? `'${brand.font_body}', ${systemStack}` : systemStack;
const themeVars = `:root{--brand:${primary};--brand-2:${secondary};--font-heading:${fontHeading};--font-body:${fontBody};}`;

const gaId = brand.google_analytics_id;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand.brand} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
    <meta name="twitter:card" content={ogImageAbs ? 'summary_large_image' : 'summary'} />
    <style set:html={themeVars}></style>
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <!-- Amazon CTAs open a new tab on desktop but hand off in the same tab on
         touch devices (Amazon-app friendly). Runs with or without GA. -->
    <script
      set:html={`document.addEventListener('click',function(e){var a=e.target.closest&&e.target.closest('a[data-amazon-cta]');if(a&&window.matchMedia('(pointer: coarse)').matches){a.target='_self';}});`}
    />
    {
      gaId && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
          <script
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');
document.addEventListener('click',function(e){var a=e.target.closest('a[data-amazon-cta]');if(!a)return;var p={asin:a.dataset.asin||'',page_type:(document.body&&document.body.dataset.pageType)||'',cta_position:a.dataset.ctaPosition||'',link_url:a.href};gtag('event','outbound_amazon_click',p);gtag('event','amazon_click',{asin:p.asin,link_url:p.link_url});});`}
          />
        </>
      )
    }
  </head>
  <body class="min-h-screen flex flex-col font-sans antialiased" data-page-type={pageType}>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
