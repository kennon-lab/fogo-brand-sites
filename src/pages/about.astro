---
import Base from '../layouts/Base.astro';
import { getBrand, getProducts } from '../lib/supabase.js';
import { localBucketImage } from '../lib/images.js';
import { getSiteContent, getCategories } from '../lib/content.js';

const brand = await getBrand();
const products = await getProducts();

// Authored brands name their own categories (needs.yaml); raw catalog
// `category` is warehouse data (Finale) and can carry junk like
// "Discontinued" — never render it on an authored brand.
const site = await getSiteContent();
const categories = site
  ? (await getCategories()).map((c) => c.display)
  : [...new Set(products.map((p) => p.category).filter(Boolean))];
const banner = brand.about_banner_path ? await localBucketImage(brand.about_banner_path, 1200) : null;
---

<Base title="About" description={`About ${brand.brand}. ${brand.tagline ?? ''}`.trim()} ogImage={banner} pageType="about">
  {
    banner && (
      <div class="mx-auto max-w-5xl px-4 pt-10">
        <img
          src={banner}
          alt={`${brand.brand} brand`}
          width="1200"
          height="600"
          fetchpriority="high"
          decoding="async"
          class="w-full rounded-3xl shadow-md"
        />
      </div>
    )
  }
  <section class="mx-auto max-w-3xl px-4 py-14">
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">About {brand.brand}</h1>
    {
      brand.about_html ? (
        <div class="mt-6 prose-desc text-lg text-black/80" set:html={brand.about_html} />
      ) : (
        <div class="mt-6 space-y-4 text-lg text-black/80">
          <p>
            {brand.brand} is dedicated to making everyday products you can rely on
            {brand.tagline ? ` — ${brand.tagline.replace(/\.$/, '').toLowerCase()}.` : '.'}
          </p>
          <p>
            Every {brand.brand} product is designed with care, backed by real customer feedback, and fulfilled
            through Amazon so you get fast, reliable shipping and easy returns.
          </p>
          {categories.length > 0 && (
            <p>
              Explore our range across {categories.join(', ').toLowerCase()} on the{' '}
              <a href="/products/" class="underline underline-offset-4 decoration-[var(--brand)] decoration-2 font-semibold">
                products page
              </a>
              .
            </p>
          )}
        </div>
      )
    }
  </section>
</Base>
